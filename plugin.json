{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-db-studio",
  "name": {
    "en": "DB Studio",
    "ko": "DB Studio"
  },
  "version": "0.0.1",
  "description": {
    "en": "Multi-DB ERD editor \u2014 schema design, migration, and SQL generation via GUI and CLI/MCP.",
    "ko": "\uba40\ud2f0-DB ERD \uc5d0\ub514\ud130 \u2014 \uc2a4\ud0a4\ub9c8 \uc124\uacc4\u00b7\ub9c8\uc774\uadf8\ub808\uc774\uc158\u00b7SQL \uc0dd\uc131\uc744 GUI \uc640 CLI/MCP \ub85c."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "commands",
    "fs:read",
    "fs:write",
    "programs",
    "data",
    "service",
    "process",
    "secrets",
    "commands:destructive"
  ],
  "service": {
    "sidecar": "db-studio",
    "interface": { "id": "soksak-spec-service", "range": "0.0.1" }
  },
  "sidecars": [
    {
      "name": "db-studio",
      "interface": { "id": "soksak-spec-sidecar-db-studio", "range": "0.0.1" }
    }
  ],
  "contributes": {
    "views": [
      {
        "id": "canvas",
        "title": {
          "en": "DB Studio",
          "ko": "DB Studio"
        },
        "icon": "\u25a4",
        "placements": [
          "content"
        ],
        "status": [],
        "defaultPlacement": "content"
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "en": "Plugin load / version check (E2E)",
          "ko": "\ud50c\ub7ec\uadf8\uc778 \uc801\uc7ac/\ubc84\uc804 \ud655\uc778(E2E)"
        }
      },
      {
        "name": "db-profile-add",
        "title": { "en": "Add connection profile", "ko": "\uc811\uc18d \ud504\ub85c\ud544 \ucd94\uac00" }
      },
      {
        "name": "db-profile-list",
        "title": { "en": "List connection profiles", "ko": "\uc811\uc18d \ud504\ub85c\ud544 \ubaa9\ub85d" }
      },
      {
        "name": "db-profile-remove",
        "title": { "en": "Remove connection profile", "ko": "\uc811\uc18d \ud504\ub85c\ud544 \uc0ad\uc81c" }
      },
      {
        "name": "db-pull-apply",
        "title": { "en": "Reverse sync into model", "ko": "\ub9ac\ubc84\uc2a4 \ub3d9\uae30\ud654" }
      },
      {
        "name": "db-push-plan",
        "title": { "en": "Forward sync plan", "ko": "\ud3ec\uc6cc\ub4dc \ub3d9\uae30\ud654 \ud50c\ub79c" }
      },
      {
        "name": "migration-run",
        "title": { "en": "Run file migrations", "ko": "\ud30c\uc77c \ub9c8\uc774\uadf8\ub808\uc774\uc158 \uc2e4\ud589" },
        "danger": "destructive"
      },
      {
        "name": "db-test",
        "title": { "en": "Test a connection", "ko": "\uc811\uc18d \ud14c\uc2a4\ud2b8" },
        "bind": "service",
        "description": "One-shot connection probe: open, apply key, read version, close.",
        "params": {
          "file": { "type": "string", "description": "SQLite file path" },
          "key": { "type": "string", "description": "SQLCipher key for an encrypted database" }
        },
        "returns": "version string"
      },
      {
        "name": "db-connect",
        "title": { "en": "Connect", "ko": "\uc811\uc18d" },
        "bind": "service",
        "danger": "destructive",
        "description": "Open a connection and hold it under the profile id (encrypted databases need their key).",
        "params": {
          "profile": { "type": "string", "required": true, "description": "Profile id the open connection is held under" },
          "file": { "type": "string", "description": "SQLite file path" },
          "key": { "type": "string", "description": "SQLCipher key for an encrypted database" }
        }
      },
      {
        "name": "db-disconnect",
        "title": { "en": "Disconnect", "ko": "\uc811\uc18d \ud574\uc81c" },
        "bind": "service",
        "description": "Drop the held connection.",
        "params": { "profile": { "type": "string", "required": true, "description": "Profile id of the held connection" } }
      },
      {
        "name": "db-status",
        "title": { "en": "Connection status", "ko": "\uc811\uc18d \uc0c1\ud0dc" },
        "bind": "service",
        "description": "List the open profiles."
      },
      {
        "name": "db-create",
        "title": { "en": "Create database", "ko": "DB \uc0dd\uc131" },
        "bind": "service",
        "danger": "destructive",
        "description": "Create a SQLite database; with a key it is encrypted (SQLCipher).",
        "params": {
          "file": { "type": "string", "required": true, "description": "Path the new SQLite file is created at" },
          "key": { "type": "string", "description": "SQLCipher key; when set the database is encrypted" }
        }
      },
      {
        "name": "db-rekey",
        "title": { "en": "Rotate encryption key", "ko": "\uc554\ud638\ud654 \ud0a4 \ud68c\uc804" },
        "bind": "service",
        "danger": "destructive",
        "description": "Rotate the SQLCipher key of a held connection (re-encrypts the whole database).",
        "params": {
          "profile": { "type": "string", "required": true, "description": "Profile id of the held connection" },
          "newKey": { "type": "string", "required": true, "description": "New SQLCipher key the database is re-encrypted with" }
        }
      },
      {
        "name": "query-run",
        "title": { "en": "Run a query", "ko": "\ucffc\ub9ac \uc2e4\ud589" },
        "bind": "service",
        "description": "Single SELECT with a row cap; sensitive columns are masked before results leave the sidecar.",
        "params": {
          "profile": { "type": "string", "required": true, "description": "Profile id of the held connection" },
          "sql": { "type": "string", "required": true, "description": "One SELECT statement" },
          "params": { "type": "json", "description": "Positional bind values for the statement" },
          "rowLimit": { "type": "number", "description": "Maximum rows returned" }
        }
      },
      {
        "name": "db-introspect",
        "title": { "en": "Introspect schema", "ko": "\uc2a4\ud0a4\ub9c8 \uc870\ud68c" },
        "bind": "service",
        "description": "Schema-only catalog (tables/columns/foreign keys/indexes); no row data.",
        "params": {
          "profile": { "type": "string", "required": true, "description": "Profile id of the held connection" },
          "tables": { "type": "string[]", "description": "Restrict to these table names; omit for all" }
        }
      },
      {
        "name": "db-audit",
        "title": { "en": "Read the audit log", "ko": "\uac10\uc0ac \ub85c\uadf8" },
        "bind": "service",
        "description": "The sidecar's append-only audit (op/profile/ok/row-count, never SQL literals).",
        "params": {
          "profile": { "type": "string", "description": "Restrict to this profile; omit for all" },
          "limit": { "type": "number", "description": "Maximum audit rows returned" }
        }
      },
      {
        "name": "db-exec",
        "title": { "en": "Execute a write", "ko": "\uc4f0\uae30 \uc2e4\ud589" },
        "bind": "service",
        "danger": "destructive",
        "description": "Single write/DDL statement; a WHERE-less DELETE/UPDATE needs force:true.",
        "params": {
          "profile": { "type": "string", "required": true, "description": "Profile id of the held connection" },
          "sql": { "type": "string", "required": true, "description": "One write or DDL statement" },
          "params": { "type": "json", "description": "Positional bind values for the statement" },
          "force": { "type": "boolean", "description": "Allow a WHERE-less DELETE/UPDATE" }
        }
      },
      {
        "name": "db-migrate",
        "title": { "en": "Apply a migration", "ko": "\ub9c8\uc774\uadf8\ub808\uc774\uc158 \uc801\uc6a9" },
        "bind": "service",
        "danger": "destructive",
        "description": "Apply one migration in a single transaction and record it in the ledger (checksum-verified).",
        "params": {
          "profile": { "type": "string", "required": true, "description": "Profile id of the held connection" },
          "id": { "type": "string", "required": true, "description": "Migration id recorded in the ledger" },
          "checksum": { "type": "string", "required": true, "description": "Checksum verified against the statements" },
          "statements": { "type": "json", "required": true, "description": "Ordered SQL statements applied in one transaction" }
        }
      },
      {
        "name": "migration-applied",
        "title": { "en": "Applied migrations", "ko": "\uc801\uc6a9\ub41c \ub9c8\uc774\uadf8\ub808\uc774\uc158" },
        "bind": "service",
        "description": "List the migration ledger for a profile.",
        "params": { "profile": { "type": "string", "required": true, "description": "Profile id of the held connection" } }
      },
      {
