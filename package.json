    "@dnd-kit/utilities": "^3.2.2",
    "@pixi/react": "^8.0.5",
    "@xyflow/react": "^12.10.0",
    "allotment": "^1.20.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fast-xml-parser": "^5.3.6",
    "immer": "^11.1.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.574.0",
    "nanoid": "^5.1.6",
    "pixi.js": "^8.16.0",
    "radix-ui": "^1.4.3",
    "rbush": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.6.4",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "zustand": "^4.5.7"
