{
  "name": "soksak-plugin-db-studio",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "soksak ERD \ud50c\ub7ec\uadf8\uc778 \u2014 abyss-erd \ud3ec\ud305(\uccab \ubc88\ub4e4 \ud50c\ub7ec\uadf8\uc778, esbuild)",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "doctor": "soksak-plugin-doctor",
    "prepublishOnly": "npm run build && npx --yes soksak-plugin-doctor .",
    "test-unit": "npm run typecheck && vitest run",
    "e2e": "node scripts/e2e/db-studio.mjs",
    "e2e-restore": "node scripts/e2e/db-studio-restore.mjs",
    "e2e:roundtrip": "DB_STUDIO_E2E=1 vitest run src/features/db/roundtrip.e2e.test.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
