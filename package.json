    "@types/dagre": "^0.7.53",
    "@types/node": "^24.10.1",
    "@types/rbush": "^4.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.24.2",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.8",
    "soksak-plugin-doctor": "github:soksak-ai/soksak-plugin-doctor"
  },
  "soksakRelease": {
